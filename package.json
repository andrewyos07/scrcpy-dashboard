{
  "name": "scrcpy-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run start:ws\"",
    "start:ws": "npm run start --prefix ./ws-scrcpy",
    "start:ws:prod": "npm start --prefix ./ws-scrcpy/dist",
    "build": "npm run build:ws && next build",
    "build:ws": "npm run dist --prefix ./ws-scrcpy",
    "start": "concurrently \"next start\" \"npm run start:ws:prod\"",
    "docker:build": "docker build -t scrcpy-dashboard .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
